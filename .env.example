# Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# OpenRouter API key (used when ai.openrouter.enabled is true)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override project root (defaults to cwd)
# MAIL_DIGEST_ROOT=D:\projects\angel\mail-digest

# Optional: personal config files (merged on top of config/*.yaml)
# MAIL_DIGEST_CONFIG=D:\projects\angel\mail-digest\config\config.local.yaml
# MAIL_DIGEST_SENDER_RULES=D:\projects\angel\mail-digest\config\sender_rules.local.yaml
